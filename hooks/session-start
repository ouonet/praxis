#!/usr/bin/env bash
# Praxis SessionStart hook - injects the startup skill into agent context.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRAXIS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Substitute {{PRAXIS_ROOT}} with the actual absolute path so fallback readers can find skill files.
startup_skill=$(sed "s|{{PRAXIS_ROOT}}|${PRAXIS_ROOT}|g" "${PRAXIS_ROOT}/skills/using-praxis/SKILL.md")
content=$(printf '<EXTREMELY_IMPORTANT>\nYou have Praxis.\n\nBelow is the full content of your '\''praxis:using-praxis'\'' skill - your introduction to using Praxis skills. For all other Praxis skills, use the Skill tool in Claude Code.\n\n%s\n</EXTREMELY_IMPORTANT>' "$startup_skill")

# JSON-escape
escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}
payload=$(escape "$content")

# Emit per-harness JSON shape.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  # Claude Code
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$payload"
elif [ -n "${COPILOT_CLI:-}" ]; then
  # Copilot CLI — SDK standard top-level additionalContext
  printf '{"additionalContext":"%s"}\n' "$payload"
else
  # Codex, OpenCode, generic SDK — hookSpecificOutput wrapper
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$payload"
fi
